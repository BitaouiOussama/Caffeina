@model Caffeina.Models.Categorie;
@{
    ViewData["Title"] = "Ajouter catégorie";
    Layout = "_layoutadmine";
}

<div id="wrapper">

    <!-- Sidebar -->
    @Html.Partial("_Navbar")
    <!-- End of Sidebar -->
    <!-- Content Wrapper -->
    <div id="content-wrapper" class="d-flex flex-column">

        <!-- Main Content -->
        <div id="content">

            <!-- Topbar -->
            @Html.Partial("_Topbar")
            <!-- End of Topbar -->
            <!-- Begin Page Content -->
            <div class="container-fluid">

                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">Ajouter - Catégorie</h1>

                </div>
                <form asp-controller="" asp-action="" method="post">
                    <div class="row mb-4">
                        <!-- Désignation Categories -->
                        <div class="col">
                            <div data-mdb-input-init class="form-outline mb-4">
                                <label class="form-label" asp-for="Designation">Désignation</label>
                                <input type="text" id="Designation" class="form-control" />
                            </div>
                        </div>
                        
                        <!-- Images Produit -->
                        <div >
                            <div data-mdb-input-init class="form-outline">
                                <label class="form-label">Image</label>
                                <input type="file" id="form6Example2" class="form-control-file" />
                            </div>
                        </div>
                    </div>
                    <!-- Submit button -->
                    <button data-mdb-ripple-init type="button" class="btn btn-admin btn-block mb-4">Ajouter</button>
                </form>
            </div>
            <!-- /.container-fluid -->

        </div>
        <!-- End of Main Content -->
        <!-- Footer -->
        @Html.Partial("_Footer")
        <!-- End of Footer -->

    </div>
    <!-- End of Content Wrapper -->

</div>
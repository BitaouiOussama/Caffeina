@model Caffeina.Models.Produit
@{
    ViewData["Title"] = "Ajouter produit";
    Layout = "_layoutadmine";
}

<div id="wrapper">

    <!-- Sidebar -->
    @Html.Partial("_Navbar")
    <!-- End of Sidebar -->
    <!-- Content Wrapper -->
    <div id="content-wrapper" class="d-flex flex-column">

        <!-- Main Content -->
        <div id="content">

            <!-- Topbar -->
            @Html.Partial("_Topbar")
            <!-- End of Topbar -->
            <!-- Begin Page Content -->
            <div class="container-fluid">

                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">Ajouter - Produit</h1>

                </div>
                <form asp-controller="" asp-action="" method="post">
                    <!-- 2 column grid layout with text inputs for the first and last names -->
                    <div class="row mb-4">
                        <!-- Labelle Produit -->
                        <div class="col">
                            <div data-mdb-input-init class="form-outline">
                                <label class="form-label" asp-for="Labelle">Labelle</label>
                                <input type="text" id="form6Example1" class="form-control" />
                            </div>
                        </div>
                        <!-- Prix Produit -->
                        <div class="col">
                            <div data-mdb-input-init class="form-outline">
                                <label class="form-label" asp-for="Prix">Prix</label>
                                <input type="text" id="form6Example2" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <!-- Listes catégorie -->
                        <div class="col">
                            <label class="form-label" for="form6Example3">Select catégorie</label>
                            <select class="form-control">
                                <option>Categ 1</option>
                                <option>Categ 2</option>
                                <option>Categ 3</option>
                            </select>
                        </div>
                        <!-- Images Produit -->
                        <div class="col">
                            <div data-mdb-input-init class="form-outline">
                                <label class="form-label" asp-for="ImageSource">Image</label>
                                <input type="file" id="form6Example2" class="form-control-file" />
                            </div>
                        </div>
                    </div>

                    
                    @*<div data-mdb-input-init class="form-outline mb-4">
                        
                    </div>*@
                    <!-- Submit button -->
                    <button data-mdb-ripple-init type="button" class="btn btn-admin btn-block mb-4">Ajouter</button>
                </form>
            </div>
            <!-- /.container-fluid -->

        </div>
        <!-- End of Main Content -->
        <!-- Footer -->
        @Html.Partial("_Footer")
        <!-- End of Footer -->

    </div>
    <!-- End of Content Wrapper -->

</div>